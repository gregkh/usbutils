setup() {
	: "${LSUSB_PY_BUILT:=$DIR/../lsusb.py}"
	: "${LSUSB_PY_INSTALLED:=$(command -v lsusb.py || true)}"
}

@test "lsusb.py -c: built and installed output is identical" {
	[ -n "$LSUSB_PY_INSTALLED" ]
	"$LSUSB_PY_BUILT"     -c > "$TEST_TMP.built"     2>&1
	"$LSUSB_PY_INSTALLED" -c > "$TEST_TMP.installed" 2>&1
	diff -u "$TEST_TMP.installed" "$TEST_TMP.built"
}

@test "lsusb.py --color: long option matches -c" {
	"$LSUSB_PY_BUILT" -c      > "$TEST_TMP.short" 2>&1
	"$LSUSB_PY_BUILT" --color > "$TEST_TMP.long"  2>&1
	diff -u "$TEST_TMP.short" "$TEST_TMP.long"
}
