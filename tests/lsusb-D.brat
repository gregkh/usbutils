# SPDX-License-Identifier: GPL-2.0-only

setup() {
	: "${LSUSB_BUILT:=$DIR/../build/lsusb}"
	: "${LSUSB_INSTALLED:=$(command -v lsusb || true)}"
	# "Bus 001 Device 001: ID 1d6b:0002 Linux Foundation ..."
	set -- $("$LSUSB_BUILT" | head -n1)
	[ $# -ge 4 ]
	devpath="/dev/bus/usb/$2/${4%:}"
	[ -e "$devpath" ]
}

@test "lsusb -D path: built and installed output is identical" {
	[ -n "$LSUSB_INSTALLED" ]
	"$LSUSB_BUILT"     -D "$devpath" > "$TEST_TMP.built"     2>&1
	"$LSUSB_INSTALLED" -D "$devpath" > "$TEST_TMP.installed" 2>&1
	diff -u "$TEST_TMP.installed" "$TEST_TMP.built"
}

@test "lsusb -D path -v: built and installed output is identical" {
	[ -n "$LSUSB_INSTALLED" ]
	"$LSUSB_BUILT"     -v -D "$devpath" > "$TEST_TMP.built"     2>&1
	"$LSUSB_INSTALLED" -v -D "$devpath" > "$TEST_TMP.installed" 2>&1
	diff -u "$TEST_TMP.installed" "$TEST_TMP.built"
}
