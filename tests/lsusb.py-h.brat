setup() {
	: "${LSUSB_PY_BUILT:=$DIR/../lsusb.py}"
	: "${LSUSB_PY_INSTALLED:=$(command -v lsusb.py || true)}"
}

@test "lsusb.py -h: built and installed help text is identical" {
	[ -n "$LSUSB_PY_INSTALLED" ]
	"$LSUSB_PY_BUILT"     -h > "$TEST_TMP.built"     2>&1
	"$LSUSB_PY_INSTALLED" -h > "$TEST_TMP.installed" 2>&1
	diff -u "$TEST_TMP.installed" "$TEST_TMP.built"
}

@test "lsusb.py --help: long option matches -h" {
	"$LSUSB_PY_BUILT" -h     > "$TEST_TMP.short" 2>&1
	"$LSUSB_PY_BUILT" --help > "$TEST_TMP.long"  2>&1
	diff -u "$TEST_TMP.short" "$TEST_TMP.long"
}
