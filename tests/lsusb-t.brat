setup() {
	: "${LSUSB_BUILT:=$DIR/../build/lsusb}"
	: "${LSUSB_INSTALLED:=$(command -v lsusb || true)}"
}

@test "lsusb -t: built and installed tree output is identical" {
	[ -n "$LSUSB_INSTALLED" ]
	"$LSUSB_BUILT"     -t > "$TEST_TMP.built"     2>&1
	"$LSUSB_INSTALLED" -t > "$TEST_TMP.installed" 2>&1
	diff -u "$TEST_TMP.installed" "$TEST_TMP.built"
}

@test "lsusb -tv: built and installed verbose tree output is identical" {
	[ -n "$LSUSB_INSTALLED" ]
	"$LSUSB_BUILT"     -tv > "$TEST_TMP.built"     2>&1
	"$LSUSB_INSTALLED" -tv > "$TEST_TMP.installed" 2>&1
	diff -u "$TEST_TMP.installed" "$TEST_TMP.built"
}

@test "lsusb --tree: long option matches -t" {
	"$LSUSB_BUILT" -t     > "$TEST_TMP.short" 2>&1
	"$LSUSB_BUILT" --tree > "$TEST_TMP.long"  2>&1
	diff -u "$TEST_TMP.short" "$TEST_TMP.long"
}
