#!/bin/sh
# SPDX-FileCopyrightText: 2026 Greg Kroah-Hartman <gregkh@linuxfoundation.org>
#
# SPDX-License-Identifier: GPL-2.0-only
#
# Compare the just-built lsusb against the installed one.
#
#   LSUSB_BUILT      path to the built binary (default: $DIR/../build/lsusb)
#   LSUSB_INSTALLED  path to the reference binary (default: lsusb from $PATH)

setup() {
	: "${LSUSB_BUILT:=$DIR/../build/lsusb}"
	: "${LSUSB_INSTALLED:=$(command -v lsusb || true)}"
}

@test "built lsusb is executable" {
	[ -x "$LSUSB_BUILT" ]
}

@test "built lsusb -V reports a version" {
	run "$LSUSB_BUILT" -V
	[ $status -eq 0 ]
	match "$stdout" '/^lsusb \(usbutils\) /'
}

@test "built lsusb -v runs" {
	run "$LSUSB_BUILT" -v
	[ $status -eq 0 ]
}

@test "installed lsusb -v runs" {
	[ -n "$LSUSB_INSTALLED" ]
	run "$LSUSB_INSTALLED" -v
	[ $status -eq 0 ]
}

@test "built and installed lsusb list the same devices" {
	[ -n "$LSUSB_INSTALLED" ]
	"$LSUSB_BUILT"     | sort > "$TEST_TMP.built"
	"$LSUSB_INSTALLED" | sort > "$TEST_TMP.installed"
	diff -u "$TEST_TMP.installed" "$TEST_TMP.built"
}

@test "built and installed lsusb -v output is identical" {
	[ -n "$LSUSB_INSTALLED" ]
	"$LSUSB_BUILT"     -v > "$TEST_TMP.built"     2>&1
	"$LSUSB_INSTALLED" -v > "$TEST_TMP.installed" 2>&1
	diff -u "$TEST_TMP.installed" "$TEST_TMP.built"
}
