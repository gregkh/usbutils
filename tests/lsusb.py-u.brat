setup() {
	: "${LSUSB_PY_BUILT:=$DIR/../lsusb.py}"
	: "${LSUSB_PY_INSTALLED:=$(command -v lsusb.py || true)}"
}

@test "lsusb.py -u: built and installed output is identical" {
	[ -n "$LSUSB_PY_INSTALLED" ]
	"$LSUSB_PY_BUILT"     -u > "$TEST_TMP.built"     2>&1
	"$LSUSB_PY_INSTALLED" -u > "$TEST_TMP.installed" 2>&1
	diff -u "$TEST_TMP.installed" "$TEST_TMP.built"
}

@test "lsusb.py --hide-empty-hubs: long option matches -u" {
	"$LSUSB_PY_BUILT" -u                > "$TEST_TMP.short" 2>&1
	"$LSUSB_PY_BUILT" --hide-empty-hubs > "$TEST_TMP.long"  2>&1
	diff -u "$TEST_TMP.short" "$TEST_TMP.long"
}
