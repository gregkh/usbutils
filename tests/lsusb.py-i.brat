setup() {
	: "${LSUSB_PY_BUILT:=$DIR/../lsusb.py}"
	: "${LSUSB_PY_INSTALLED:=$(command -v lsusb.py || true)}"
}

@test "lsusb.py -i: built and installed output is identical" {
	[ -n "$LSUSB_PY_INSTALLED" ]
	"$LSUSB_PY_BUILT"     -i > "$TEST_TMP.built"     2>&1
	"$LSUSB_PY_INSTALLED" -i > "$TEST_TMP.installed" 2>&1
	diff -u "$TEST_TMP.installed" "$TEST_TMP.built"
}

@test "lsusb.py --interfaces: long option matches -i" {
	"$LSUSB_PY_BUILT" -i           > "$TEST_TMP.short" 2>&1
	"$LSUSB_PY_BUILT" --interfaces > "$TEST_TMP.long"  2>&1
	diff -u "$TEST_TMP.short" "$TEST_TMP.long"
}
